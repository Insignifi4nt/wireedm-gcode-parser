{
  "name": "wire-edm-gcode-viewer",
  "homepage": "https://insignifi4nt.github.io/wireedm-gcode-parser",
  "version": "1.0.0",
  "description": "A Wire EDM G-Code Viewer application with interactive visualization and measurement tools",
  "type": "module",
  "main": "src/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist -m \"deploy: $(git rev-parse --short HEAD)\"",
    "test": "vitest",
    "connect": "bash scripts/connect-browser.sh"
  },
  "keywords": [
    "wire-edm",
    "gcode",
    "cnc",
    "viewer",
    "machining"
  ],
  "author": "Wire EDM Development Team",
  "license": "MIT",
  "devDependencies": {
    "jsdom": "^29.1.1",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": "^20.19.0 || >=22.13.0"
  },
  "dependencies": {
    "gh-pages": "^6.3.0"
  }
}
