{
  "name": "wire-edm-workbench",
  "homepage": "https://insignifi4nt.github.io/wireedm-gcode-parser",
  "version": "0.1.0",
  "description": "A local-first Wire EDM workbench for DXF import, clean IJ G-code generation, editing, verification, and export.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist -m \"deploy: $(git rev-parse --short HEAD)\"",
    "test": "vitest"
  },
  "keywords": [
    "wire-edm",
    "dxf",
    "gcode",
    "cnc",
    "cam",
    "local-first"
  ],
  "author": "Wire EDM Development Team",
  "license": "MIT",
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.1.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dxf": "^5.3.1",
    "gh-pages": "^6.3.0",
    "lucide-react": "^0.555.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.2",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": "^20.19.0 || >=22.13.0"
  }
}
